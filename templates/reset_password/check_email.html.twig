{% extends 'base.html.twig' %}

{% block title %}Email envoyé — Musically
{% endblock %}

{% block h1 %}
	<h1 class="page-h1">Email envoyé</h1>
{% endblock %}

{% block body %}
	<div class="auth-form">
		<div class="form-alert form-alert--success">
			Si un compte correspond à votre adresse email, un lien de réinitialisation vient d'être envoyé.
			Ce lien expirera dans
			{{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}.
		</div>

		<p class="auth-form__switch">
			Vous n'avez pas reçu l'email ? Vérifiez vos spams ou
			<a href="{{ path('app_forgot_password_request') }}">réessayez</a>.
		</p>
	</div>
{% endblock %}
