{% extends 'base.html.twig' %}

{% block title %}Nouveau mot de passe — Musically
{% endblock %}

{% block h1 %}
	<h1 class="page-h1">Nouveau mot de passe</h1>
{% endblock %}

{% block body %}
	{{ form_start(resetForm, {attr: {class: 'auth-form'}}) }}
	<div class="auth-form__field">
		{{ form_label(resetForm.plainPassword, null, {label_attr: {class: 'auth-form__label'}}) }}
		{{ form_widget(resetForm.plainPassword, {attr: {class: 'auth-form__input'}}) }}
		{{ form_errors(resetForm.plainPassword) }}
	</div>
	<button type="submit" class="auth-form__submit">Réinitialiser le mot de passe</button>
	{{ form_end(resetForm) }}
{% endblock %}
