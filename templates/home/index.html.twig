{% extends 'base.html.twig' %}

{% block title %}Accueil
{% endblock %}

{% block h1 %}{% endblock %}

{% block body %}

	{# ========== HERO ========== #}
	<section class="hero">
		<div class="hero__content">
			<h1 class="hero__title">Des créations musicales pour tous vos événements</h1>
			<p class="hero__subtitle">Mariage • Anniversaire • Soirée • Naissance</p>
			<a href="{{ path('app_catalogue') }}" class="hero__cta">Découvrir le catalogue</a>
		</div>
	</section>

	{# ========== GRILLE CATÉGORIES ========== #}
	<section class="home-categories">
		<h2 class="home-categories__title">Explorez par occasion</h2>
		<div class="home-categories__grid">

			<a href="{{ path('app_catalogue') }}?category=5" class="category-card">
				<img src="{{ asset('images/mariage.jpg') }}" alt="Mariage" class="category-card__img">
				<div class="category-card__overlay">
					<span class="category-card__label">Musique mariage</span>
				</div>
			</a>

			<a href="{{ path('app_catalogue') }}?category=7" class="category-card">
				<img src="{{ asset('images/anniverssaire.jpg') }}" alt="Anniversaire" class="category-card__img">
				<div class="category-card__overlay">
					<span class="category-card__label">Musique anniversaire</span>
				</div>
			</a>

			<a href="{{ path('app_catalogue') }}?category=6" class="category-card">
				<img src="{{ asset('images/naissance.jpg') }}" alt="Naissance" class="category-card__img">
				<div class="category-card__overlay">
					<span class="category-card__label">Musique naissance</span>
				</div>
			</a>

			<a href="{{ path('app_catalogue') }}" class="category-card">
				<img src="{{ asset('images/autres.jpg') }}" alt="Autres projets" class="category-card__img">
				<div class="category-card__overlay">
					<span class="category-card__label">Autres projets musicaux</span>
				</div>
			</a>

		</div>
	</section>

	{# ========== DÉMOS ========== #}
	<section class="home-demos">
		<h2 class="home-demos__title">Écoutez quelques exemples</h2>
		<div class="home-demos__grid">

			<button type="button" class="demo-card">
				<span class="demo-card__icon">▶</span>
				<span class="demo-card__label">Démo 1</span>
			</button>

			<button type="button" class="demo-card">
				<span class="demo-card__icon">▶</span>
				<span class="demo-card__label">Démo 2</span>
			</button>

			<button type="button" class="demo-card">
				<span class="demo-card__icon">▶</span>
				<span class="demo-card__label">Démo 3</span>
			</button>

		</div>
	</section>

{% endblock %}
