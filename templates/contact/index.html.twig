{% extends 'base.html.twig' %}

{% block title %}Contact
{% endblock %}

{% block h1 %}
	<h1 class="page-h1">Contact</h1>
{% endblock %}

{% block body %}

	<div
		class="contact">

		{# ========== COORDONNÉES ========== #}
		<div class="contact__info">
			<h2 class="contact__info-title">Coordonnées</h2>

			<div class="contact__info-item">
				<span class="contact__info-icon">📞</span>
				<span>06 00 00 00 00</span>
			</div>

			<div class="contact__info-item">
				<span class="contact__info-icon">📍</span>
				<span>10 rue de Paris, 75000 Paris</span>
			</div>

			<div class="contact__info-item">
				<span class="contact__info-icon">✉️</span>
				<a href="mailto:contact@musically.fr">contact@musically.fr</a>
			</div>
		</div>

		{# ========== FORMULAIRE ========== #}
		<div class="contact__form-wrapper">
			<h2 class="contact__form-title">Envoyer un message</h2>

			{# Message de succès #}
			{% for message in app.flashes('success') %}
				<div class="form-alert form-alert--success">
					✓
					{{ message }}
				</div>
			{% endfor %}

			{{ form_start(form, {attr: {class: 'contact__form'}}) }}

			<div class="form-field">
				{{ form_label(form.firstname, null, {label_attr: {class: 'form-field__label'}}) }}
				{{ form_widget(form.firstname, {attr: {class: 'form-field__input'}}) }}
				{{ form_errors(form.firstname) }}
			</div>

			<div class="form-field">
				{{ form_label(form.lastname, null, {label_attr: {class: 'form-field__label'}}) }}
				{{ form_widget(form.lastname, {attr: {class: 'form-field__input'}}) }}
				{{ form_errors(form.lastname) }}
			</div>

			<div class="form-field">
				{{ form_label(form.phone, null, {label_attr: {class: 'form-field__label'}}) }}
				{{ form_widget(form.phone, {attr: {class: 'form-field__input'}}) }}
				{{ form_errors(form.phone) }}
			</div>

			<div class="form-field">
				{{ form_label(form.email, null, {label_attr: {class: 'form-field__label'}}) }}
				{{ form_widget(form.email, {attr: {class: 'form-field__input'}}) }}
				{{ form_errors(form.email) }}
			</div>

			<div class="form-field">
				{{ form_label(form.message, null, {label_attr: {class: 'form-field__label'}}) }}
				{{ form_widget(form.message, {attr: {class: 'form-field__input form-field__input--textarea'}}) }}
				{{ form_errors(form.message) }}
			</div>

			<button type="submit" class="form-submit">Envoyer</button>

			{{ form_end(form) }}
		</div>

	</div>

{% endblock %}
